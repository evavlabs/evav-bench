# oa-bench environment variables — copy to .env and fill in.
# .env is gitignored.

# Model API keys (set whichever providers you use)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...

# Logging
OA_LOG_LEVEL=INFO

# Masking classifier — stage 2 (LLM-based) uses claude-haiku by default.
# Set to "0" to disable LLM classification (CI / cheap audits).
OA_STAGE2_CLASSIFIER=1
OA_MASKING_CLASSIFIER=claude-haiku-4-5

# Supabase mode (only needed for --supabase flag)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-SERVICE-OR-ANON-KEY

# Windows encoding fix for OpenRouter
PYTHONIOENCODING=utf-8
